generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  name  String?  @db.VarChar(25)
  phone String   @id @db.VarChar(16)
  role  UserRole @default(CLIENT)

  meetings           Meeting[]
  services           Service[]
  schedules          Schedule[]
  scheduleExceptions ScheduleException[]
  pushSubscriptions  PushSubscription[]
}

enum UserRole {
  BARBER
  CLIENT
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  userPhone String
  user      User     @relation(fields: [userPhone], references: [phone])
}

model Service {
  id              String        @id @default(uuid())
  name            String        @db.VarChar(32)
  priceCents      Int
  durationMinutes Int
  isActive        Boolean       @default(true)

  meetings    Meeting[]

  barber      User          @relation(fields: [barberPhone], references: [phone])
  barberPhone String
}

model Meeting {
  id         String            @id @default(uuid())
  date       DateTime
  clientName String
  status     MeetingStatus     @default(SCHEDULED)

  user       User              @relation(fields: [userPhone], references: [phone])
  userPhone  String

  service    Service           @relation(fields: [serviceId], references: [id])
  serviceId  String
}

enum MeetingStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

model Schedule {
  id         String  @id @default(uuid())
  dayOfWeek  Int // 0 = Domingo, 1 = Segunda...
  
  // Horários no formato "HH:mm"
  openTime   String
  closeTime  String
  
  lunchStart String
  lunchEnd   String

  barber      User          @relation(fields: [barberPhone], references: [phone])
  barberPhone String

  @@unique([barberPhone, dayOfWeek])
}

model ScheduleException {
  id          String   @id @default(uuid())
  date        DateTime @unique // O dia específico (ex: 2026-04-21)
  description String   @db.VarChar(48)
  
  openTime    String
  closeTime   String

  lunchStart  String
  lunchEnd    String

  barber      User          @relation(fields: [barberPhone], references: [phone])
  barberPhone String
}
