{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "outDir": "../../dist/apps/api",
    "baseUrl": "../../",
    "paths": {
      "@common/*": ["apps/api/src/common/*"],
      "@modules/*": ["apps/api/src/modules/*"],
