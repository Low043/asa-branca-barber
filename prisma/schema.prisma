generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  phone String @id @db.VarChar(16)

  meetings Meeting[]
}

model Service {
  id              String        @id @default(uuid())
  name            String        @db.VarChar(32)
  priceCents      Int
  durationMinutes Int
  isActive        Boolean       @default(true)

  meetings    Meeting[]
}

model Meeting {
  id         String            @id @default(uuid())
  date       DateTime
  clientName String
  status     MeetingStatus     @default(SCHEDULED)

  user       User              @relation(fields: [userPhone], references: [phone])
  userPhone  String

  service    Service           @relation(fields: [serviceId], references: [id])
  serviceId  String

  @@unique([date]) // Garante que não haja dois agendamentos no mesmo horário
}

enum MeetingStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

model Schedule {
  dayOfWeek  Int     @id // 0 = Domingo, 1 = Segunda...
  
  // Horários no formato "HH:mm"
  openTime   String
  closeTime  String
  
  lunchStart String
  lunchEnd   String
}

model ScheduleException {
  id          String   @id @default(uuid())
  date        DateTime @unique // O dia específico (ex: 2026-04-21)
  description String   @db.VarChar(48)
  
  openTime    String
  closeTime   String

  lunchStart  String
  lunchEnd    String
}
